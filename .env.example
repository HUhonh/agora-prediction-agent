# ============================================================
# Agora Prediction Agent 环境配置
# 复制此文件为 .env 并填入你的密钥
# ============================================================

# --- Polymarket ---
# 你的 Polymarket 钱包私钥 (Polygon)
POLY_PRIVATE_KEY=YOUR_PRIVATE_KEY
# Polymarket 钱包地址 (Gnosis Safe 或 EOA)
POLY_FUNDER_ADDRESS=YOUR_FUNDER_ADDRESS

# --- Polymarket Builder (分成) ---
# 在 https://developers.polymarket.com 申请
POLY_BUILDER_API_KEY=YOUR_BUILDER_API_KEY
POLY_BUILDER_SECRET=YOUR_BUILDER_SECRET
POLY_BUILDER_PASSPHRASE=YOUR_BUILDER_PASSPHRASE

# --- Optional: Arc ---
# Arc 测试网私钥 (已有的话)
ARC_PRIVATE_KEY=YOUR_ARC_PRIVATE_KEY
