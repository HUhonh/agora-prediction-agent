# ============================================================
# Agora Prediction Agent 环境配置
# 复制此文件为 .env 并填入你的密钥
# ============================================================

# --- Polymarket ---
# 你的 Polymarket 钱包私钥 (Polygon)
PRIVATE_KEY=YOUR_PRIVATE_KEY
# Polymarket 钱包地址 (Gnosis Safe 或 EOA)
FUNDER_ADDRESS=YOUR_FUNDER_ADDRESS

# --- Polymarket Builder (分成) ---
# 在 https://developers.polymarket.com 申请
POLY_BUILDER_API_KEY=YOUR_BUILDER_API_KEY
POLY_BUILDER_SECRET=YOUR_BUILDER_SECRET
POLY_BUILDER_PASSPHRASE=YOUR_BUILDER_PASSPHRASE

# --- Optional: Arc ---
# Arc 测试网私钥 (已有的话)
ARC_PRIVATE_KEY=YOUR_ARC_PRIVATE_KEY
# Arc 验证者钱包私钥 (给 Agent 打分，ERC-8004 要求不同钱包)
ARC_VALIDATOR_KEY=YOUR_ARC_VALIDATOR_KEY

# --- Optional: Chainlink Data Streams ---
CHAINLINK_API_KEY=YOUR_CHAINLINK_API_KEY
CHAINLINK_API_SECRET=YOUR_CHAINLINK_API_SECRET
CHAINLINK_API_HOST=api.dataengine.chain.link
BTC_FEED_ID=0x00039d9e45394f473ab1f050a1b963e6b05351e52d71e507509ada0c95ed75b8
